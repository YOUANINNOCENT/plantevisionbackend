# Exemple .env pour le backend FastAPI
# Copiez ce fichier en `.env` et remplacez les valeurs par les vôtres

# URL de connexion PostgreSQL
# Format: postgresql://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql://plante_user:VotreMotDePasse@127.0.0.1:5432/plante_db
# PlantNet API (identification des plantes)
# Obtenez une clé sur https://plantnet.org ou utilisez votre instance PlantNet
PLANTNET_API_KEY=VotreClePlantNet
# Optionnel: URL API (par défaut: https://my-api.plantnet.org/v2/identify)
PLANTNET_API_URL=https://my-api.plantnet.org/v2/identify/all
